#!/usr/bin/env bash
# cc-pacekeeper hook entrypoint: refresh (PostToolUse)
# Spawns the OAuth refresh detached so the hook returns in <5ms.
# The refresh script self-gates on cache staleness (>180s) so spawning every
# call is harmless.
set -euo pipefail
# Hooks must never break Claude's workflow: without Bun, no-op cleanly.
if ! command -v bun >/dev/null 2>&1; then
  echo "cc-pacekeeper: Bun not found on PATH — hooks are inert. Install it (https://bun.sh, e.g. 'brew install oven-sh/bun/bun') and restart Claude Code." >&2
  echo '{}'
  exit 0
fi
DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
# Capture stdin to a temp file so the detached refresh can read the PostToolUse
# payload (model / transcript_path) to populate the per-model context-window
# cache. Feeding it /dev/null here silently disabled that population.
STDIN_TMP="$(mktemp -t pacekeeper-refresh.XXXXXX)"
cat > "$STDIN_TMP"
# Detach the refresh; the subshell feeds it the payload then deletes the temp
# file. stdout/stderr ignored so the parent returns immediately.
# setsid(1) does not exist on macOS; nohup + background + disown achieves the
# same "survives the hook's exit, no terminal" detach portably.
nohup bash -c "bun run --silent '$DIR/../src/refresh.ts' < '$STDIN_TMP'; rm -f '$STDIN_TMP'" < /dev/null > /dev/null 2>&1 &
disown 2>/dev/null || true
echo '{}'
