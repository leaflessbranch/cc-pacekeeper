#!/usr/bin/env bash
# cc-pacekeeper PreToolUse hook for cron tools: auto-approves only the plugin's
# own keepalive-scoped CronCreate/CronDelete; everything else falls through.
set -euo pipefail
# Hooks must never break Claude's workflow: without Bun, no-op cleanly.
if ! command -v bun >/dev/null 2>&1; then
  echo "cc-pacekeeper: Bun not found on PATH — hooks are inert. Install it (https://bun.sh, e.g. 'brew install oven-sh/bun/bun') and restart Claude Code." >&2
  echo '{}'
  exit 0
fi
DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
exec bun run --silent "$DIR/../src/approve.ts"
