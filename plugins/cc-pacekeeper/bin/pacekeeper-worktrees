#!/usr/bin/env bash
# cc-pacekeeper worktrees: prints git worktrees + dirty/live-session state as
# JSON. Invoked by the /cc-pacekeeper:worktree skill's `list` verb.
set -euo pipefail
if ! command -v bun >/dev/null 2>&1; then
  echo "cc-pacekeeper: this command needs the Bun runtime, which was not found on PATH." >&2
  echo "Install it from https://bun.sh (macOS: 'brew install oven-sh/bun/bun'), then re-run." >&2
  exit 1
fi
DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
exec bun run --silent "$DIR/../src/worktrees.ts" "$@"
